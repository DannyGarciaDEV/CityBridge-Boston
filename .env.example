# MBTA (optional; public endpoints may work without key depending on rate limits)
MBTA_API_KEY=

# Deepgram — server-side only; kiosk calls /api/deepgram/transcribe in dev/preview
DEEPGRAM_API_KEY=

# VoiceRun — base URL of your VoiceRun HTTP API + bearer key
VOICERUN_API_BASE=
VOICERUN_API_KEY=

# Kiosk: path appended to /api/voicerun (must start with /)
VITE_VOICERUN_TRANSCRIBE_PATH=/v1/transcribe

# MCP server: Boston research via Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

