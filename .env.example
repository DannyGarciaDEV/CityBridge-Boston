# Repo root — copy to `.env` for local dev and set the same keys in Vercel for production.

# MBTA (recommended in production; helps rate limits on /api/mbta/stops)
MBTA_API_KEY=

# Kiosk chat + Vercel serverless `/api/boston-chat`
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Deepgram STT/TTS for mic + “play last reply”
DEEPGRAM_API_KEY=
# DEEPGRAM_TTS_MODEL=

# Override path to resources.json (default: repo data/ or kiosk build snapshot)
# RESOURCES_JSON_PATH=
