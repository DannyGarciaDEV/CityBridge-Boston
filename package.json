{
  "name": "mcp-boss",
  "private": true,
  "description": "CityBridge Boston — AI civic resource decision assistant (MCP server, curated data, kiosk UI).",
  "engines": {
    "node": "20.x || 22.x"
  },
  "devDependencies": {
    "@vercel/node": "^5.7.13"
  },
  "scripts": {
    "prefetch": "node scripts/run-prefetch.mjs",
    "dev": "npm run dev:kiosk",
    "start": "npm run dev:kiosk",
    "install:server": "npm --prefix server install",
    "install:kiosk": "npm --prefix kiosk install",
    "install:vercel": "npm install && npm run install:kiosk",
    "build:mcp": "npm --prefix server run build",
    "build:kiosk": "npm --prefix kiosk run build",
    "build": "npm run prefetch && npm run build:mcp && npm run build:kiosk",
    "vercel-build": "node scripts/run-prefetch.mjs && node scripts/vercel-build.mjs",
    "setup:server": "npm run install:server && npm run build:mcp",
    "dev:kiosk": "npm --prefix kiosk run dev",
    "dev:mcp": "npm --prefix server run dev",
    "mcp": "node server/mcp-launch.mjs"
  }
}
