{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install && cd .. && python3 -m pip install --user -q -r requirements.txt",
  "buildCommand": "cd .. && python3 scripts/fetch_resources.py && cd kiosk && npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" }
      ]
    }
  ],
  "functions": {
    "api/boston-chat.ts": {
      "maxDuration": 60,
      "includeFiles": "api/resources.snapshot.json"
    },
    "api/deepgram/transcribe.ts": {
      "maxDuration": 60
    },
    "api/deepgram/speak.ts": {
      "maxDuration": 45
    },
    "api/mbta/stops.ts": {
      "maxDuration": 25
    }
  }
}
