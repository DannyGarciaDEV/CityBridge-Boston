{
  "name": "boston-resource-kiosk",
  "version": "0.1.0",
  "description": "CityBridge Boston kiosk — map, categories, and chat UI for civic resource guidance.",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x || 22.x"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node ./scripts/prepare-server-data.mjs",
