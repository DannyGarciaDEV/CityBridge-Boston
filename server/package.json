{
  "name": "boston-resource-mcp",
  "version": "0.1.0",
  "description": "MCP server for CityBridge Boston — tool-based access to curated civic resource data.",
  "private": true,
  "type": "module",
  "bin": {
    "boston-resource-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "setup": "npm install && npm run build",
    "setup:server": "npm install && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
